# Banco de dados MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=financeiro
MYSQL_USER=root
MYSQL_PASSWORD=

# Seguranca / JWT
JWT_SECRET=troque-este-valor-por-uma-chave-aleatoria-longa
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REMEMBER_ME_EXPIRE_MINUTES=43200

# Administrador unico (criado no primeiro startup via seed)
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@financeiro.com.br
ADMIN_PASSWORD=Admin@123

# Regras de dominio
EMAIL_DOMAIN=@financeiro.com.br
PASSWORD_RESET_EXPIRE_MINUTES=30

# SMTP (opcional). Sem isso, o link de reset fica visivel no painel admin e em log.
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=nao-responda@financeiro.com.br
SMTP_TLS=true

# URL base usada para montar o link de redefinicao de senha
APP_BASE_URL=http://localhost:8000
